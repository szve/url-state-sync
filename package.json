{
  "name": "url-state-sync",
  "version": "0.1.0",
  "description": "Minimal URL ⇄ state sync store — framework-agnostic, zero-dependency.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "url",
    "query",
    "querystring",
    "state",
    "sync",
    "url-state",
    "search-params",
    "history"
  ],
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "happy-dom": "^20.0.0",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
