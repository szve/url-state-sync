{
    "name": "url-state-sync-monorepo",
    "type": "module",
    "version": "0.0.0",
    "private": true,
    "description": "url-state-sync monorepo — minimal URL ⇄ state sync store",
    "scripts": {
        "build": "pnpm -r --filter url-state-sync build",
        "test": "pnpm -r --filter url-state-sync test",
