{
    "name": "url-state-sync",
    "type": "module",
    "version": "0.0.1",
    "description": "Minimal URL ⇄ state sync store — framework-agnostic, zero-dependency.",
    "author": "szve",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/szve/url-state-sync.git",
        "directory": "packages/core"
    },
    "bugs": "https://github.com/szve/url-state-sync/issues",
    "keywords": [
        "url",
        "query",
        "querystring",
        "state",
        "sync",
        "url-state",
        "search-params",
        "history"
    ],
    "sideEffects": false,
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        }
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist",
        "src"
    ],
    "engines": {
        "node": ">=16.6"
    },
    "scripts": {
        "build": "tsdown",
        "dev": "tsdown --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit",
        "prepack": "pnpm build"
    },
    "devDependencies": {
        "happy-dom": "^20.0.0",
        "tsdown": "^0.22.3",
        "typescript": "^6.0.3",
        "vitest": "^4.1.9"
    }
}
